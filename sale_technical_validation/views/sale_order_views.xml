<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_technical" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.technical</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Buttons -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_send_to_scale" string="Send to Scale" type="object" 
                        class="oe_stat_button" icon="fa-paper-plane"
                        invisible="[('state', '!=', 'draft')]" groups="base.group_user">
                    <field name="state" invisible="1"/>
                </button>
                <button name="action_verify_data" string="Verify Scale" type="object" 
                        class="oe_stat_button" icon="fa-check-circle"
                        invisible="[('state', '!=', 'waiting_scale')]" groups="sale_technical_validation.group_technical_office">
                    <field name="state" invisible="1"/>
                </button>
                <button name="action_send_for_pricing" string="Send for Pricing" type="object" 
                        class="oe_stat_button" icon="fa-dollar"
                        invisible="[('state', '!=', 'waiting_scale')]" groups="sale_technical_validation.group_technical_office">
                    <field name="state" invisible="1"/>
                </button>
            </xpath>

            <!-- Technical Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="technical_request" string="Technical Request">
                    <group>
                        <field name="checklist_template_id"/>
                        <field name="checklist_progress_rate" widget="progressbar"/>
                    </group>
                    <field name="checklist_line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle" column_invisible="True"/>
                            <field name="name" readonly="1"/>
                            <field name="is_mandatory" readonly="1"/>
                            <field name="is_completed"/>
                        </list>
                    </field>
                    <p class="text-muted mt-2">
                        <i class="fa fa-info-circle"/> Checklist tasks must be checked manually. Mandatory items are required before sending for pricing.
                    </p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>