<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_technical" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.technical</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Stat Button in Button Box (More robust against Smile patching) -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_send_to_scale" string="Send to Scale" type="object" 
                        class="oe_stat_button" 
                        icon="fa-ruler"
                        invisible="[('state', '!=', 'draft')]"
                        groups="base.group_user">
                    <field name="state" invisible="1"/>
                </button>
            </xpath>

            <!-- Add Technical Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="technical_request" string="Technical Request">
                    <group>
                        <field name="is_technical_verified"/>
                        <field name="x_checklist_progress_rate" widget="progressbar"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>