<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_technical" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.technical</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Add Button in Header -->
            <xpath expr="//header" position="inside">
                <button name="action_send_to_scale" string="Send to Scale" type="object" 
                        class="oe_highlight" 
                        invisible="[('state', '!=', 'draft')]"
                        groups="base.group_user"/>
            </xpath>

            <!-- Add Technical Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="technical_request" string="Technical Request">
                    <group>
                        <field name="is_technical_verified"/>
                        <field name="x_checklist_progress_rate" widget="progressbar"/>
                    </group>
                    <!-- Note: The Smile module injects the checklist button/instances dynamically. 
                         We rely on that for the actual task list. -->
                </page>
            </xpath>
        </field>
    </record>
</odoo>