<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_technical" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.technical</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- 1. Sales Button: Send to Scale -->
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button name="action_send_to_scale" string="Send to Scale" type="object" 
                        class="oe_highlight" 
                        invisible="[('state', '!=', 'draft')]"
                        groups="base.group_user"/>
            </xpath>

            <!-- 2. Technical Buttons: Verify & Send for Pricing -->
            <xpath expr="//button[@name='action_send_to_scale']" position="after">
                <button name="action_verify_data" string="Verify Data" type="object" 
                        class="oe_highlight" 
                        invisible="[('state', '!=', 'waiting_scale')]"
                        groups="sale_technical_validation.group_technical_office"/>
                        
                <button name="action_send_for_pricing" string="Send for Pricing" type="object" 
                        class="oe_highlight" 
                        invisible="[('state', '!=', 'waiting_scale')]"
                        groups="sale_technical_validation.group_technical_office"/>
            </xpath>

            <!-- 3. Technical Tab -->
            <xpath expr="//page[@name='order_lines']" position="after">
                <page name="technical_request" string="Technical Request">
                    <group>
                        <field name="is_technical_verified"/>
                        <field name="x_checklist_progress_rate" widget="progressbar"/>
                    </group>
                    <p class="text-muted">
                        <strong>Note:</strong> Checklist items will automatically mark as "Done" when you click "Verify Data".
                    </p>
                </page>
            </xpath>
        </field>
    </record>
</odoo>