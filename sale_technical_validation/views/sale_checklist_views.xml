<!-- Checklist Template Form View -->
<record id="view_sale_checklist_template_form" model="ir.ui.view">
    <field name="name">sale.checklist.template.form</field>
    <field name="model">sale.checklist.template</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <div class="oe_title">
                    <label for="name"/>
                    <h1><field name="name" placeholder="e.g. Technical Validation Checklist"/></h1>
                </div>
                <group>
                    <field name="active" widget="boolean_toggle"/>
                </group>
                <notebook>
                    <page string="Checklist Items">
                        <field name="line_ids" context="{'default_is_mandatory': False}">
                            <list editable="bottom" create="1" edit="1" delete="1">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="is_mandatory"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </sheet>
        </form>
    </field>
</record>