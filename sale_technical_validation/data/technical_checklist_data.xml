<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="checklist_technical_validation" model="checklist">
            <field name="name">Technical Validation</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="active_field" eval="False"/>
        </record>

        <record id="task_check_dimensions" model="checklist.task">
            <field name="name">Dimensions Verified</field>
            <field name="checklist_id" ref="checklist_technical_validation"/>
            <field name="sequence">10</field>
            <field name="mandatory" eval="True"/>
            <!-- Set a domain that is FALSE by default, so user MUST check it manually if we add a manual override field, 
                 BUT Smile module computes 'complete' based on domain. 
                 To make it manual, we usually need a boolean field on the instance. 
                 Since Smile doesn't have a manual checkbox by default, we rely on the Domain. 
                 Let's set a domain that requires a specific field to be true. -->
            <field name="complete_domain">[('is_technical_verified', '=', True)]</field>
        </record>

        <record id="task_check_material" model="checklist.task">
            <field name="name">Material Specification Confirmed</field>
            <field name="checklist_id" ref="checklist_technical_validation"/>
            <field name="sequence">20</field>
            <field name="mandatory" eval="False"/>
             <field name="complete_domain">[('is_technical_verified', '=', True)]</field>
        </record>
    </data>
</odoo>